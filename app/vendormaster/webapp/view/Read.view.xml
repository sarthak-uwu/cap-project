<mvc:View
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.ui.layout.form"
  controllerName="vendormaster.controller.Read"
  displayBlock="true">

  <Page title="Read Vendor" showNavButton="true" navButtonPress="onNavBack">
    <content>

      <Panel class="sapUiMediumMargin">
        <f:SimpleForm
          editable="true"
          layout="ResponsiveGridLayout"
          labelSpanL="3"
          labelSpanM="3"
          emptySpanL="1"
          emptySpanM="1"
          columnsL="1"
          columnsM="1">

          <f:content>
            <Label text="Vendor ID" required="true"/>
            <Input id="readVendorId" width="50%"/>
          </f:content>

        </f:SimpleForm>

        <Toolbar>
          <ToolbarSpacer/>
          <Button text="Fetch Record" type="Emphasized" press="onFetch"/>
          <ToolbarSpacer/>
        </Toolbar>
      </Panel>

      <Panel class="sapUiMediumMargin">
        <VBox id="readResult" class="sapUiSmallMargin"/>
      </Panel>

    </content>
  </Page>

</mvc:View>